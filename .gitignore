# Ignore everything by default
*
 
# --- Then explicitly allow your custom folders ---
# Uncomment and rename these to match your actual folder names:
 
!themes/
!themes/execheads/
!themes/execheads/**
!plugins/
!plugins/exec-heads-jobadder/
!plugins/exec-heads-jobadder/**
!plugins/exheads/
!plugins/exheads/**
!.github/
!.github/workflows/
!.github/workflows/**
 
# Allow .gitignore files within those folders
!.gitignore
 
# Always ignore these even if inside tracked folders
uploads/
upgrade/
cache/
backup*/
*.log
 